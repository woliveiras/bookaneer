# Bookaneer — Environment Variables
# Copy this file to .env and adjust as needed.

# Server port (default: 9090)
BOOKANEER_PORT=9090

# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
BOOKANEER_BIND_ADDRESS=0.0.0.0

# Data directory — stores database, config, logs (inside Docker: /data)
BOOKANEER_DATA_DIR=/data

# Library directory — where your ebooks are stored (inside Docker: /library)
BOOKANEER_LIBRARY_DIR=/library

# Log level: debug, info, warn, error
BOOKANEER_LOG_LEVEL=info

# Admin password — set on first boot only. If unset, a random password is generated
# and saved to /data/admin_credentials.txt
# BOOKANEER_ADMIN_PASSWORD=

# Host path to your ebook library (used in docker-compose.yml)
LIBRARY_PATH=./library
